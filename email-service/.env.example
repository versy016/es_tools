# Copy to .env (do NOT commit .env) or set these as Lambda environment variables.
# Example values shown for Microsoft 365 / Outlook SMTP — replace with your server.

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=reports@engsurveys.com.au
SMTP_PASS=your-smtp-password-or-app-password
SMTP_FROM=Engineering Surveys <reports@engsurveys.com.au>
